<Window x:Class="SwgLaunchpad.App.AddServerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add a server" Height="300" Width="520"
        Background="{StaticResource BgBrush}"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <StackPanel Margin="20">
        <TextBlock Text="Add a server" FontSize="18" FontWeight="SemiBold"
                   Foreground="{StaticResource GoldBrush}" Margin="0,0,0,10"/>

        <TextBlock TextWrapping="Wrap" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,12">
            Paste the server's manifest address. Every listed server publishes one — ask in
            the server's Discord for their "Launchpad manifest URL", or find it on their website.
            It looks like:  https://patch.yourserver.org/manifest.json
        </TextBlock>

        <TextBox x:Name="SourceBox" FontFamily="Consolas" Margin="0,0,0,8"
                 KeyDown="OnSourceKeyDown"/>

        <TextBlock TextWrapping="Wrap" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,0,0,16">
            Servers you add yourself are marked "custom" and aren't reviewed by the r/swg moderators —
            only add servers you trust. You can remove a custom server at any time; installed files stay on disk.
        </TextBlock>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Click="OnCancel"/>
            <Button Content="Add server" Style="{StaticResource PlayButton}" Click="OnAdd"/>
        </StackPanel>
    </StackPanel>
</Window>
