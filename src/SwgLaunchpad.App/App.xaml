<Application x:Class="SwgLaunchpad.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <!-- SWG night-sky theme: deep navy, gold accents (r/swg styling) -->
        <SolidColorBrush x:Key="BgBrush" Color="#FF0A0E1A"/>
        <SolidColorBrush x:Key="PanelBrush" Color="#FF141A2A"/>
        <SolidColorBrush x:Key="PanelHoverBrush" Color="#FF1A2236"/>
        <SolidColorBrush x:Key="GoldBrush" Color="#FFFFD54A"/>
        <SolidColorBrush x:Key="GoldDimBrush" Color="#FFD4A843"/>
        <SolidColorBrush x:Key="TextBrush" Color="#FFE8EAF0"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#FF8C93A8"/>
        <SolidColorBrush x:Key="OnlineBrush" Color="#FF40C463"/>
        <SolidColorBrush x:Key="OfflineBrush" Color="#FFE05252"/>
        <SolidColorBrush x:Key="UnknownBrush" Color="#FF6A7186"/>

        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="#FF222B42"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="4,0,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF2C3754"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PlayButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="{StaticResource GoldBrush}"/>
            <Setter Property="Foreground" Value="#FF1A1404"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="22,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FFFFE27A"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" BasedOn="{StaticResource ActionButton}"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="#FF2C3754"/>
            <Setter Property="Padding" Value="6,5"/>
            <Setter Property="CaretBrush" Value="{StaticResource GoldBrush}"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
            <Setter Property="Foreground" Value="#FF1A1F2E"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>

        <!-- Lightsaber progress bar (Restoration-style): hilt + glowing green blade -->
        <Style x:Key="LightsaberProgress" TargetType="ProgressBar">
            <Setter Property="Height" Value="10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="22"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <!-- hilt -->
                            <Border Grid.Column="0" CornerRadius="2" Margin="0,0,2,0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#FFB9BFCC" Offset="0"/>
                                        <GradientStop Color="#FF6A7186" Offset="0.5"/>
                                        <GradientStop Color="#FF3A4050" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                            <!-- blade track -->
                            <Border Grid.Column="1" x:Name="PART_Track" Background="#FF10141F" CornerRadius="0,5,5,0"/>
                            <Border Grid.Column="1" x:Name="PART_Indicator" HorizontalAlignment="Left"
                                    CornerRadius="0,5,5,0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#FFD8FFE2" Offset="0.45"/>
                                        <GradientStop Color="#FF40C463" Offset="0.5"/>
                                        <GradientStop Color="#FF1E7A3C" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Effect>
                                    <DropShadowEffect Color="#FF40C463" BlurRadius="12" ShadowDepth="0" Opacity="0.9"/>
                                </Border.Effect>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Application.Resources>
</Application>
