<Window x:Class="SwgLaunchpad.App.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Account" Height="380" Width="440"
        Background="{StaticResource BgBrush}"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <StackPanel Margin="24">
        <TextBlock x:Name="HeaderText" FontSize="18" FontWeight="SemiBold"
                   Foreground="{StaticResource GoldBrush}"/>
        <TextBlock x:Name="SubText" Foreground="{StaticResource MutedBrush}" Margin="0,4,0,16"
                   Text="This server uses launcher accounts. Your credentials are encrypted with Windows DPAPI and stored only on this PC."
                   TextWrapping="Wrap" FontSize="11"/>

        <TextBlock Text="Username" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,4"/>
        <TextBox x:Name="UsernameBox" Margin="0,0,0,12"/>

        <TextBlock Text="Password" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,4"/>
        <PasswordBox x:Name="PasswordBox" Margin="0,0,0,10"
                     Background="{StaticResource PanelBrush}" Foreground="{StaticResource TextBrush}"
                     BorderBrush="#FF2C3754" Padding="6,5"/>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock x:Name="ForgotLink" Foreground="{StaticResource GoldDimBrush}" FontSize="12"
                       Cursor="Hand" MouseLeftButtonUp="OnForgot" TextDecorations="Underline"
                       Text="Forgot your password?"/>
            <TextBlock x:Name="RegisterLink" Foreground="{StaticResource GoldDimBrush}" FontSize="12"
                       Cursor="Hand" MouseLeftButtonUp="OnRegister" TextDecorations="Underline"
                       Margin="18,0,0,0" Text="Don't have an account? Join for free"/>
        </StackPanel>

        <TextBlock x:Name="StatusText" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,0,0,10"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Clear saved" Click="OnClear"/>
            <Button Content="Cancel" Click="OnCancel"/>
            <Button Content="Save &amp; Sign in" Style="{StaticResource PlayButton}" Click="OnSave"/>
        </StackPanel>
    </StackPanel>
</Window>
