<Window x:Class="SwgLaunchpad.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Game Settings" Height="320" Width="420"
        Background="{StaticResource BgBrush}"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <StackPanel Margin="16">
        <TextBlock x:Name="HeaderText" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"
                   Foreground="{StaticResource GoldBrush}"/>

        <TextBlock Text="Resolution" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,4"/>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
            <TextBox x:Name="WidthBox" Width="80"/>
            <TextBlock Text=" x " VerticalAlignment="Center" Margin="6,0"/>
            <TextBox x:Name="HeightBox" Width="80"/>
        </StackPanel>

        <CheckBox x:Name="WindowedBox" Content="Windowed mode" Margin="0,0,0,8"/>
        <CheckBox x:Name="SkipIntroBox" Content="Skip intro movies" Margin="0,0,0,16"/>

        <TextBlock Text="Settings are per-server; other servers are unaffected."
                   Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,0,0,12"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Click="OnCancel"/>
            <Button Content="Save" Style="{StaticResource PlayButton}" Click="OnSave"/>
        </StackPanel>
    </StackPanel>
</Window>
